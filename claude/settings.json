{
  "permissions": {
    "deny": [
      "Write(~/.ssh/**)",
      "Edit(~/.ssh/**)",
      "Write(//etc/**)",
      "Edit(//etc/**)",
      "Write(~/.claude/hooks/**)",
      "Edit(~/.claude/hooks/**)",
      "Read(~/.claude/hooks/**)",
      "Edit(~/.claude/settings.json)",
      "Write(~/.claude/settings.json)",
      "Edit(~/.claude/settings.local.json)",
      "Write(~/.claude/settings.local.json)",
      "Edit(~/.claude/policy-limits.json)",
      "Write(~/.claude/policy-limits.json)",
      "Read(~/.claude/.credentials.json)",
      "Edit(~/.claude/.credentials.json)",
      "Write(~/.claude/.credentials.json)",
      "Bash(*push*--force*)",
      "Bash(*reset*--hard*)",
      "Bash(*clean*-f*)",
      "Bash(*filter-branch*)",
      "Bash(*filter-repo*)",
      "Bash(*branch*-D*)",
      "Bash(*push*--delete*)",
      "Bash(*commit*--amend*)",
      "Bash(*submit*)",
      "Bash(*obliterate*)",
      "Bash(*admin*)",
      "Bash(*protect*)",
      "Bash(*triggers*)",
      "Bash(*configure*)",
      "Bash(*depot*-d*)",
      "Bash(*stream*-d*)",
      "Bash(*branch*-d*)",
      "Bash(*label*-d*)",
      "Bash(*shelve*-d*)",
      "Bash(*user*-d*)",
      "Bash(*group*-d*)",
      "Bash(*rm -rf*)",
      "Bash(*rm -fr*)",
      "Bash(*rm -f /*)",
      "Bash(*shred*)",
      "Bash(*dd *)",
      "Bash(*mkfs*)",
      "Bash(*fdisk*)",
      "Bash(*parted*)",
      "Bash(*truncate*)",
      "Bash(*base64*-d*)",
      "Bash(*base64*--decode*)",
      "Read(~/.ssh/**)",
      "Read(//home/dev/.ssh/**)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(~/.aws/**)",
      "Read(~/.config/gcloud/**)",
      "Grep(~/.ssh/**)",
      "Grep(**/.env)",
      "Grep(**/*.pem)",
      "Grep(**/*.key)",
      "Grep(~/.aws/**)"
    ],
    "defaultMode": "default",
    "disableBypassPermissionsMode": "disable"
  },
  "model": "sonnet",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell|mcp__.*",
        "hooks": [{ "type": "command", "command": "~/.claude/hooks/guard.sh" }]
      },
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit|Read|Grep",
        "hooks": [{ "type": "command", "command": "~/.claude/hooks/path-guard.sh" }]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"SessionStart\",\"additionalContext\":\"Caveman mode is active. Respond terse like smart caveman. Drop articles, filler words, pleasantries, hedging. Fragments OK. Short synonyms. Technical terms exact. Code blocks unchanged. Pattern: [thing] [action] [reason]. [next step].\"}}'",
            "statusMessage": "Activating caveman mode..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /home/dev/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "caveman@caveman": true,
    "teamcity-cli@teamcity-cli": true,
    "voltagent-core-dev@voltagent": true,
    "voltagent-lang@voltagent": true,
    "voltagent-infra@voltagent": true,
    "voltagent-qa-sec@voltagent": true,
    "voltagent-data-ai@voltagent": true,
    "voltagent-dev-exp@voltagent": true,
    "voltagent-domains@voltagent": true,
    "voltagent-biz@voltagent": true,
    "voltagent-meta@voltagent": true,
    "voltagent-research@voltagent": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "voltagent": {
      "source": {
        "source": "github",
        "repo": "VoltAgent/awesome-claude-code-subagents"
      }
    },
    "teamcity-cli": {
      "source": {
        "source": "github",
        "repo": "JetBrains/teamcity-cli"
      }
    }
  },
  "awaySummaryEnabled": false,
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true,
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [" "]
  }
}
